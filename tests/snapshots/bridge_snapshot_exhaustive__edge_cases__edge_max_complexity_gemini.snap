expression: "&req"
---
model: gemini-2.5-pro
contents:
  - role: user
    parts:
      - text: Analyze this data
      - inlineData:
          mimeType: image/png
          data: base64data==
  - role: model
    parts:
      - functionCall:
          name: analyze
          args:
            data: sample
            mode: deep
  - role: user
    parts:
      - functionResponse:
          name: analyze
          response:
            confidence: 0.95
            result: complex output
tools:
  - functionDeclarations:
      - name: analyze
        description: Analyze data deeply
        parameters:
          properties:
            data:
              type: string
            mode:
              type: string
          type: object
      - name: summarize
        description: Summarize results
        parameters:
          properties:
            text:
