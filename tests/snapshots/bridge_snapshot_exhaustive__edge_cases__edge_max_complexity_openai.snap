---
source: tests/bridge_snapshot_exhaustive.rs
expression: "&req"
---
model: gpt-4o
messages:
  - role: system
    content: You are an advanced data analyst.
  - role: user
    content: Analyze this dataset
  - role: assistant
    tool_calls:
      - id: call_a1
        type: function
        function:
          name: analyze
          arguments: "{\"data\":\"sample\",\"mode\":\"deep\"}"
      - id: call_a2
        type: function
        function:
          name: summarize
          arguments: "{\"text\":\"results\"}"
  - role: tool
    content: "{\"result\":\"complex output\",\"confidence\":0.95}"
    tool_call_id: call_a1
  - role: tool
    content: "Summary: data looks good"
    tool_call_id: call_a2
tools:
  - type: function
    function:
      name: analyze
      description: Analyze data deeply
      parameters:
        properties:
          data:
            type: string
          mode:
            type: string
        type: object
  - type: function
    function:
      name: summarize
      description: Summarize results
      parameters:
        properties:
          text:
            type: string
        type: object
temperature: 0.5
max_tokens: 8192
stream: true
top_p: 0.85
frequency_penalty: 0.2
presence_penalty: 0.1
stop:
  - HALT
  - QUIT
n: 1
tool_choice: auto
