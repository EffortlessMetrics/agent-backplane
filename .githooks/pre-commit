#!/usr/bin/env bash
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# Exit if no Rust/Cargo files staged
if ! git diff --cached --name-only --diff-filter=ACMR | grep -qE '\.rs$|(^|/)Cargo\.toml$|^Cargo\.lock$'; then
  exit 0
fi

# Capture originally-staged files (NUL-delimited, safe for spaces/special chars)
staged_list="$(mktemp)"
trap 'rm -f "$staged_list"' EXIT
git diff --cached --name-only --diff-filter=ACMR -z > "$staged_list"

echo "pre-commit: lint-fix"
cargo xtask lint-fix

# Re-stage exactly what was staged (NUL-safe)
xargs -0 git add -- < "$staged_list"

# Best-effort typos check (only if installed)
if command -v typos &>/dev/null; then
  echo "pre-commit: typos"
  typos --diff
fi
